{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "terminal_background": "#1A1A1A",
  "patch_pwsh_bleed": true,
  "palette": {
    "xbox-green": "#107C10",
    "xbox-bright": "#52B043",
    "xbox-neon": "#9BF00B",
    "xbox-black": "#000000",
    "xbox-dark": "#1A1A1A",
    "xbox-surface": "#2D2D2D",
    "xbox-white": "#FFFFFF",
    "xbox-light": "#D2D2D2",
    "xbox-red": "#E74856",
    "xbox-amber": "#F7630C",
    "xbox-blue": "#0078D4"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "background": "p:xbox-green",
          "foreground": "p:xbox-white",
          "template": "\uDB81\uDDB9{{ if .WSL }}WSL{{ end }}"
        },
        {
          "type": "shell",
          "style": "diamond",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "background": "p:xbox-surface",
          "foreground": "p:xbox-light",
          "template": " {{ .Name }} "
        },
        {
          "type": "path",
          "style": "diamond",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "background": "p:xbox-surface",
          "foreground": "p:xbox-bright",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "folder_separator_icon": " \ue0b1 "
          },
          "template": " \uf07b {{ .Path }} "
        },
        {
          "type": "git",
          "style": "diamond",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "background": "p:xbox-surface",
          "foreground": "p:xbox-bright",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:xbox-amber{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#6A0572{{ end }}",
            "{{ if gt .Ahead 0 }}p:xbox-blue{{ end }}",
            "{{ if gt .Behind 0 }}p:xbox-blue{{ end }}"
          ],
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:xbox-black{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:xbox-white{{ end }}",
            "{{ if gt .Ahead 0 }}p:xbox-white{{ end }}",
            "{{ if gt .Behind 0 }}p:xbox-white{{ end }}"
          ],
          "properties": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "merge_icon": "\ue727 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \uf01c {{ .StashCount }}{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "background": "p:xbox-surface",
          "foreground": "p:xbox-light",
          "properties": {
            "threshold": 500,
            "style": "roundrock"
          },
          "template": " \uf252 {{ .FormattedMs }} "
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "dotnet",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "background": "p:xbox-surface",
          "foreground": "#0d6da8",
          "properties": {
            "display_mode": "files"
          },
          "template": " \ue77f {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} "
        },
        {
          "type": "node",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "background": "p:xbox-surface",
          "foreground": "#3C873A",
          "properties": {
            "display_mode": "files"
          },
          "template": " \ue718 {{ .Full }} "
        },
        {
          "type": "python",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "background": "p:xbox-surface",
          "foreground": "#FFD43B",
          "properties": {
            "display_mode": "files",
            "fetch_virtual_env": true
          },
          "template": " \ue235 {{ if .Venv }}({{ .Venv }}) {{ end }}{{ .Full }} "
        },
        {
          "type": "time",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "background": "p:xbox-green",
          "foreground": "p:xbox-white",
          "template": " \uf017 {{ .CurrentDate | date \"15:04\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:xbox-surface",
          "template": "\u2570\u2500"
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:xbox-bright",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:xbox-red{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "template": " \u2756 "
        }
      ]
    }
  ],
  "transient_prompt": {
    "background": "transparent",
    "foreground": "p:xbox-green",
    "template": "\uDB81\uDDB9 "
  },
  "console_title_template": "{{ .Shell }} \u2500 {{ .Folder }}"
}
